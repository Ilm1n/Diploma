@startuml
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle

actor "Пользователь" as User
actor "Участник проекта" as Member
actor "Менеджер проекта" as Manager
actor "Владелец проекта" as Owner

Member --|> User
Manager --|> Member
Owner --|> Manager

rectangle "Kantano: проекты, команда и приглашения" {
  package "Проекты" {
    usecase "Просматривать список проектов" as UC_ListProjects
    usecase "Создать проект" as UC_CreateProject
    usecase "Просматривать данные проекта" as UC_ViewProject
    usecase "Обновить проект" as UC_UpdateProject
    usecase "Удалить проект" as UC_DeleteProject
  }

  package "Участники" {
    usecase "Просматривать участников проекта" as UC_ViewMembers
    usecase "Удалять участника" as UC_RemoveMember
    usecase "Изменять роль участника" as UC_ChangeRole
  }

  package "Приглашения" {
    usecase "Создавать приглашение" as UC_CreateInvite
    usecase "Настраивать роль, email,\nсрок действия и лимит использований" as UC_ConfigInvite
    usecase "Просматривать приглашения" as UC_ViewInvites
    usecase "Удалять приглашение" as UC_DeleteInvite
    usecase "Копировать ссылку приглашения" as UC_CopyInvite
    usecase "Показывать QR-код приглашения" as UC_ShowInviteQr
    usecase "Принимать приглашение" as UC_AcceptInvite
  }
}

User --> UC_ListProjects
User --> UC_CreateProject
User --> UC_AcceptInvite

Member --> UC_ViewProject
Member --> UC_ViewMembers

Manager --> UC_RemoveMember
Manager --> UC_CreateInvite
Manager --> UC_ViewInvites
Manager --> UC_DeleteInvite
Manager --> UC_CopyInvite
Manager --> UC_ShowInviteQr

Owner --> UC_UpdateProject
Owner --> UC_DeleteProject
Owner --> UC_ChangeRole

UC_CreateInvite .> UC_ConfigInvite : <<include>>

@enduml
