# ============================================================
# LightTask / Kantano - Development .env template (root)
# Реально используется backend config + docker-compose.dev.yml
# ============================================================

# -----------------------------
# REQUIRED (backend runtime)
# -----------------------------
LIGHTTASK_CONFIG__DB__USER=lighttask_user
LIGHTTASK_CONFIG__DB__PASSWORD=change_me_db_password
LIGHTTASK_CONFIG__DB__NAME=lighttask

LIGHTTASK_CONFIG__S3__ACCESS_KEY=change_me_s3_access_key
LIGHTTASK_CONFIG__S3__SECRET_KEY=change_me_s3_secret_key
LIGHTTASK_CONFIG__S3__BUCKET_NAME=change_me_s3_bucket

# Для localhost по HTTP (refresh cookie).
# Для production оставляем True (default backend config).
LIGHTTASK_CONFIG__AUTH_JWT__SECURE=False

# -----------------------------
# OPTIONAL overrides
# -----------------------------
LIGHTTASK_CONFIG__DB__HOST=localhost
LIGHTTASK_CONFIG__DB__PORT=5432
LIGHTTASK_CONFIG__DB__ECHO=0

LIGHTTASK_CONFIG__RUN__HOST=0.0.0.0
LIGHTTASK_CONFIG__RUN__PORT=8000
LIGHTTASK_CONFIG__RUN__CORS_ORIGINS=["http://localhost:5173","http://localhost:4173","http://127.0.0.1:5173"]

LIGHTTASK_CONFIG__INVITE__BASE_URL=http://localhost:5173/invite
LIGHTTASK_CONFIG__FRONTEND__BASE_URL=http://localhost:5173
LIGHTTASK_CONFIG__REALTIME__REDIS_URL=redis://localhost:6379/0
LIGHTTASK_CONFIG__REALTIME__REDIS_CHANNEL=realtime.v1.events

LIGHTTASK_CONFIG__AUTH_JWT__ACCESS_TOKEN_EXPIRE_MINUTES=15
LIGHTTASK_CONFIG__AUTH_JWT__REFRESH_TOKEN_EXPIRE_DAYS=30

# Yandex OAuth / Yandex ID.
# Для production callback: https://kantano.ru/api/auth/yandex/callback
LIGHTTASK_CONFIG__YANDEX__CLIENT_ID=
LIGHTTASK_CONFIG__YANDEX__CLIENT_SECRET=
LIGHTTASK_CONFIG__YANDEX__REDIRECT_URI=http://localhost:8000/api/auth/yandex/callback

# -----------------------------
# OPTIONAL (S3 advanced)
# -----------------------------
LIGHTTASK_CONFIG__S3__ENDPOINT_URL=https://s3.ru1.storage.beget.cloud
LIGHTTASK_CONFIG__S3__REGION_NAME=ru1
