# ============================================================
# LightTask / Kantano - Production .env template (manual deploy)
# Используется docker-compose.prod.yml
# ============================================================

# -----------------------------
# REQUIRED in production compose
# -----------------------------
LIGHTTASK_CONFIG__DB__PASSWORD=change_me_db_password

LIGHTTASK_CONFIG__S3__ACCESS_KEY=change_me_s3_access_key
LIGHTTASK_CONFIG__S3__SECRET_KEY=change_me_s3_secret_key
LIGHTTASK_CONFIG__S3__BUCKET_NAME=change_me_s3_bucket

LIGHTTASK_CONFIG__YANDEX__CLIENT_ID=change_me_yandex_client_id
LIGHTTASK_CONFIG__YANDEX__CLIENT_SECRET=change_me_yandex_client_secret
LIGHTTASK_CONFIG__YANDEX__REDIRECT_URI=https://kantano.ru/api/auth/yandex/callback
LIGHTTASK_CONFIG__FRONTEND__BASE_URL=https://kantano.ru

IMAGE_REPO_OWNER=your_ghcr_owner
IMAGE_TAG=main

# Получить hash:
# docker run --rm caddy caddy hash-password --plaintext "your_password"
SWAGGER_HASH=change_me_caddy_bcrypt_hash

# -----------------------------
# OPTIONAL overrides
# -----------------------------
LIGHTTASK_CONFIG__AUTH_JWT__ACCESS_TOKEN_EXPIRE_MINUTES=15
LIGHTTASK_CONFIG__AUTH_JWT__REFRESH_TOKEN_EXPIRE_DAYS=30
LIGHTTASK_CONFIG__REALTIME__REDIS_CHANNEL=realtime.v1.events
LIGHTTASK_CONFIG__REALTIME__PRESENCE_TTL_SECONDS=30
LIGHTTASK_CONFIG__REALTIME__PRESENCE_SYNC_INTERVAL_SECONDS=10
LIGHTTASK_CONFIG__S3__ENDPOINT_URL=https://s3.ru1.storage.beget.cloud
LIGHTTASK_CONFIG__S3__REGION_NAME=ru1

# Notes:
# - DB host/user/name/port заданы в docker-compose.prod.yml.
# - RUN host/port/CORS и INVITE base URL тоже заданы в compose.
# - JWT key files должны лежать в ./certs (см. backend/light_task/src/auth/README.md).
